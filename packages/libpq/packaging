#!/bin/bash -exu

function main() {
  local pgversion
  pgversion="postgresql-16.9"

  tar xzf "postgres/${pgversion}.tar.gz"

  pushd "${pgversion}" > /dev/null
    ./configure --prefix="${BOSH_INSTALL_TARGET}" --with-openssl

    pushd src/bin/pg_config > /dev/null
      make
      make install
    popd > /dev/null

    cp -LR src/include "${BOSH_INSTALL_TARGET}"

    pushd src/interfaces/libpq > /dev/null
      make
      make install
    popd > /dev/null
  popd > /dev/null

  # Ensure unversioned linker name exists so -lpq can resolve
  if [ -d "${BOSH_INSTALL_TARGET}/lib" ]; then
    pushd "${BOSH_INSTALL_TARGET}/lib" > /dev/null
      if [ ! -f libpq.so ] && ls libpq.so.* >/dev/null 2>&1; then
        latest=$(ls -1 libpq.so.* | sort -V | tail -n1)
        ln -sf "$latest" libpq.so
      fi
    popd > /dev/null
  fi
}

main
